# LogMind Environment Configuration Template
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# ── App ──────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=<generate-a-random-secret-key>
JWT_SECRET_KEY=<generate-a-random-jwt-secret>
ENCRYPTION_KEY=<run-python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">

# ── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://logmind:logmind@localhost:5432/logmind
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ───────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Elasticsearch ────────────────────────────────────
ES_HOSTS=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_CERTS=false
ES_REQUEST_TIMEOUT=30

# ── MinIO (RAG Document Storage) ────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=logmind
MINIO_SECRET_KEY=logmind123456
MINIO_BUCKET=logmind-docs
MINIO_SECURE=false

# ── AI Analysis Cost Control ─────────────────────────
ANALYSIS_SEVERITY_THRESHOLD=error
ANALYSIS_MAX_LOGS_PER_TASK=500
ANALYSIS_DAILY_TASK_LIMIT=100
ANALYSIS_COOLDOWN_MINUTES=30
ANALYSIS_FINGERPRINT_ENABLED=true
ANALYSIS_FINGERPRINT_TTL_HOURS=6
ANALYSIS_AGENT_ENABLED=true
ANALYSIS_AGENT_MAX_STEPS=5

# ── Semantic Dedup ───────────────────────────────────
ANALYSIS_SEMANTIC_DEDUP_ENABLED=true
ANALYSIS_SEMANTIC_DEDUP_THRESHOLD=0.92
ANALYSIS_SEMANTIC_DEDUP_TTL_HOURS=168
ANALYSIS_EMBEDDING_CACHE_TTL_SECONDS=3600
